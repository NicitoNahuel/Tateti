public enum Opciones{
    CRUZ{
        public String parseString(){
            return "X"
        }
    },

    
    CIRCULO{
        public String parseString(){
            return "O"
        }
    },
    
    VACIO;
    
    public String abstract parseString(){

    }
    
    public Opciones abstract contrario(Opciones o){
        if(o == Opciones.CIRCULO){
        return Opciones.CRUZ;  
        } else {
            return Opciones.CIRCULO;
        } 
    }
}
